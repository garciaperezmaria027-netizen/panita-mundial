# --- MundialBot 2026 - Variables de Entorno ---

# API Key de Gemini (Google AI Studio)
GEMINI_API_KEY=tu_api_key_de_gemini

# OpenRouter (Acceso a múltiples modelos de IA con fallbacks)
OPENROUTER_API_KEY=tu_api_key_de_openrouter
# Modelos separados por coma, en orden de prioridad. Ej: google/gemini-2.5-flash:free,qwen/qwen3-coder:free,deepseek/deepseek-chat:free,openrouter/free
OPENROUTER_MODELS=google/gemini-2.5-flash:free,qwen/qwen3-coder:free,deepseek/deepseek-chat:free,openrouter/free

# API-Football (api-sports.io)
API_FOOTBALL_KEY=tu_api_key_de_api_football
API_FOOTBALL_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026

# Teléfono del Administrador (incluyendo código de país, sin '+' ni espacios, ej: 573001234567)
ADMIN_PHONE=573000000000

# Proveedor de Datos Deportivos: 'free-2026' o 'api-football'
SPORTS_PROVIDER=free-2026
